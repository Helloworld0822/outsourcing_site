# ===========================================
# Outsourcing Hub - 환경변수 설정
# ===========================================
# .env 파일을 만들고 아래 변수들을 설정하세요.
# cp .env.example .env

# -------------------------------------------
# Database
# -------------------------------------------
DB_NAME=outsourcing_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# -------------------------------------------
# JWT / Security
# -------------------------------------------
# 프로덕션에서는 반드시 변경하세요 (최소 32자)
JWT_SECRET=dev_jwt_secret
SECRET_KEY_BASE=dev_secret

# -------------------------------------------
# OpenAI API (AI 추천 기능)
# -------------------------------------------
OPENAI_API_KEY=

# -------------------------------------------
# Resend (이메일 발송)
# -------------------------------------------
# https://resend.com 에서 API 키를 발급하세요.
# 미설정 시 인증 메일이 콘솔에 출력됩니다.
RESEND_API_KEY=

# 발신자 이메일 (Resend 무료 플랜: onboarding@resend.dev 사용 가능)
# 프로덕션에서는 본인 도메인으로 변경하세요.
EMAIL_FROM=Outsourcing Hub <onboarding@resend.dev>

# -------------------------------------------
# Email Verification
# -------------------------------------------
# 인증 링크의 기본 URL (프로덕션에서는 도메인으로 변경)
EMAIL_VERIFICATION_BASE_URL=http://localhost:5173

# -------------------------------------------
# Backend Server
# -------------------------------------------
PORT=4000
WS_PORT=4001

# -------------------------------------------
# Frontend (Vite)
# -------------------------------------------
CHOKIDAR_USEPOLLING=true
WATCHPACK_POLLING=true
