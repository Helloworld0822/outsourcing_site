# ===========================================
# Outsourcing Hub - 환경변수 설정
# ===========================================
# .env 파일을 만들고 아래 변수들을 설정하세요.
# cp .env.example .env

# -------------------------------------------
# Database
# -------------------------------------------
DB_NAME=outsourcing_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# -------------------------------------------
# JWT / Security
# -------------------------------------------
# 프로덕션에서는 반드시 변경하세요 (최소 32자)
JWT_SECRET=dev_jwt_secret
SECRET_KEY_BASE=dev_secret

# -------------------------------------------
# OpenAI API (AI 추천 기능)
# -------------------------------------------
OPENAI_API_KEY=

# -------------------------------------------
# Email Verification
# -------------------------------------------
# 인증 링크의 기본 URL (프로덕션에서는 도메인으로 변경)
EMAIL_VERIFICATION_BASE_URL=http://localhost:5173

# -------------------------------------------
# SMTP (이메일 발송용)
# -------------------------------------------
# 미설정 시 이메일이 콘솔에 출력됩니다.
# 프로덕션에서는 SMTP 설정을 입력하세요.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# -------------------------------------------
# Backend Server
# -------------------------------------------
PORT=4000
WS_PORT=4001

# -------------------------------------------
# Frontend (Vite)
# -------------------------------------------
CHOKIDAR_USEPOLLING=true
WATCHPACK_POLLING=true
