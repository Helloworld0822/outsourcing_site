# ===========================================
# Crewlink - 환경변수 설정
# ===========================================
# .env 파일을 만들고 아래 변수들을 설정하세요.
#   cp .env.example .env
# 프로덕션에서는 모든 *REQUIRED* 항목을 반드시 강력한 값으로 교체하세요.

# -------------------------------------------
# Database
# -------------------------------------------
DB_NAME=outsourcing_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
# Connection pool size (per backend instance). CPU cores * 2 is a good
# starting point; raise if you see pool saturation in metrics.
DB_POOL_SIZE=10
# Enable SSL/TLS to the database. Required in prod.
DB_SSL=false
# Path to the CA bundle used to verify the database server certificate.
DB_CACERTFILE=
# Ecto SQL log level: false | info | debug | warning
DB_LOG_LEVEL=false

# -------------------------------------------
# JWT / Security (REQUIRED in prod/staging, ≥ 32 chars)
# -------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET=dev_jwt_secret
SECRET_KEY_BASE=dev_secret
# Comma-separated list of allowed CORS origins, e.g.
# CORS_ALLOWED_ORIGINS=https://crewlink.io,https://www.crewlink.io
CORS_ALLOWED_ORIGINS=http://localhost:82,http://localhost:5173

# -------------------------------------------
# OpenAI API (AI 추천 기능) - Optional
# -------------------------------------------
OPENAI_API_KEY=

# -------------------------------------------
# Resend (이메일 발송) - Optional
# -------------------------------------------
# https://resend.com 에서 API 키를 발급하세요.
# 미설정 시 인증 메일이 콘솔에 출력됩니다.
RESEND_API_KEY=

# 발신자 이메일. 프로덕션에서는 본인 도메인을 사용하세요.
EMAIL_FROM=Crewlink <no-reply@crewlink.io>

# 인증 링크의 기본 URL (프로덕션에서는 도메인으로 변경)
EMAIL_VERIFICATION_BASE_URL=http://localhost:82

# -------------------------------------------
# Backend Server
# -------------------------------------------
PORT=4000
WS_PORT=4001
# Graceful shutdown timeout (ms). On SIGTERM the app stops accepting new
# connections, broadcasts a drain to WS subscribers, and waits up to this
# many milliseconds for in-flight work before exiting.
SHUTDOWN_TIMEOUT=30000

# -------------------------------------------
# Frontend (Vite dev)
# -------------------------------------------
CHOKIDAR_USEPOLLING=true
WATCHPACK_POLLING=true
# Optional: bake into the build by setting at build time.
# VITE_API_BASE=https://api.crewlink.io
# VITE_WS_BASE=wss://api.crewlink.io/ws
